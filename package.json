{
  "name": "pod-mpc-lib",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "postinstall": "patch-package",
    "node:chain1": "HARDHAT_CHAIN_ID=31337 hardhat node --port 8545",
    "node:chain2": "HARDHAT_CHAIN_ID=31338 hardhat node --port 8546",
    "deploy:inbox": "hardhat run scripts/deploy-inbox.ts",
    "deploy:inbox:avax": "hardhat run scripts/deploy-inbox.ts --network avalancheFuji",
    "deploy:inbox:sepolia": "hardhat run scripts/deploy-inbox.ts --network sepolia",
    "deploy:oracle": "hardhat run scripts/deploy-oracle.ts",
    "deploy:inbox:coti": "hardhat run scripts/deploy-inbox-with-executor.ts --network cotiTestnet",
    "deploy:full-testnet": "hardhat run scripts/deploy-full-testnet.ts",
    "deploy:full-testnet:avax": "SOURCE_NETWORK=avalancheFuji hardhat run scripts/deploy-full-testnet.ts",
    "deploy:cli": "hardhat compile && node --import tsx scripts/deploy-cli.ts",
    "deploy:mpc-executor": "hardhat run scripts/deploy-mpc-executor.ts",
    "deploy:examples:source": "hardhat run scripts/deploy-examples-source.ts",
    "deploy:examples:coti": "hardhat run scripts/deploy-examples-coti.ts",
    "deploy:privacy:factories": "hardhat run scripts/privacyPortal/deploy-factories.ts",
    "deploy:privacy:source-factory": "hardhat run scripts/privacyPortal/deploy-source-factory.ts",
    "deploy:privacy:coti-mother": "hardhat run scripts/privacyPortal/deploy-coti-mother.ts",
    "deploy:privacy:source-portal": "hardhat run scripts/privacyPortal/deploy-source-portal.ts",
    "deploy:privacy:token": "hardhat run scripts/privacyPortal/deploy-token.ts",
    "deploy:privacy:sync": "hardhat run scripts/privacyPortal/sync-token-list.ts",
    "test": "hardhat test",
    "test:executor-coti": "hardhat test test/system/mpc-executor-coti.ts",
    "test:gt64-repro": "hardhat test test/Gt64GasRepro.ts",
    "test:inbox-fee": "NODE_OPTIONS='--max-old-space-size=8192' hardhat test test/InboxFeeCalculation.ts",
    "test:inbox": "hardhat test test/Inbox.ts",
    "test:inbox-raise": "hardhat test test/system/inbox-raise.ts",
    "test:pod-token": "POD_TOKEN_SYSTEM_TESTS=1 hardhat test test/tokens/pod-token.ts",
    "test:pod-token-late-onboard": "POD_TOKEN_LATE_ONBOARD_TESTS=1 hardhat test test/tokens/pod-token-late-onboard.ts",
    "investigate:offboard-to-user": "OFFBOARD_TO_USER_INVESTIGATION=1 hardhat test test/tokens/offboard-to-user-investigation.ts",
    "test:pp-system": "PP_SYSTEM_TESTS=1 hardhat test test/privacy/privacy-portal-system.ts",
    "test:erc7984": "hardhat test test/erc7984/erc7984-compat.ts test/erc7984/portal-wrapper.ts test/erc7984/dummy-sync-flow.ts",
    "test:erc7984-explorer": "ERC7984_EXPLORER_TESTS=1 hardhat test test/erc7984/blockscout-explorer.ts",
    "demo:erc7984-sepolia": "hardhat run scripts/erc7984/run-sepolia-demo.ts --network sepolia",
    "demo:erc7984-dummy-sepolia": "hardhat run scripts/erc7984/run-dummy-explorer-demo.ts --network sepolia",
    "relay": "tsx scripts/relay-node.ts"
  },
  "devDependencies": {
    "@coti-io/coti-ethers": "^1.0.5",
    "@coti-io/coti-sdk-typescript": "^1.0.7",
    "@nomicfoundation/hardhat-ignition": "^3.0.6",
    "@nomicfoundation/hardhat-toolbox-viem": "^5.0.1",
    "@types/node": "^22.19.5",
    "dotenv": "^17.4.2",
    "ethers": "^6.15.0",
    "forge-std": "github:foundry-rs/forge-std#v1.9.4",
    "hardhat": "^3.1.3",
    "patch-package": "^8.0.1",
    "solc": "0.8.28",
    "tsx": "^4.19.2",
    "typescript": "~5.8.0",
    "viem": "^2.44.1"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.4.0"
  }
}
